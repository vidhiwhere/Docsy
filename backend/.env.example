# Docsy Environment Configuration
# Copy this file to .env and fill in your values

# --- NLP Mode ---
# Set to "openai" to use OpenAI API (recommended)
# Set to "local" to use sentence-transformers (free, offline)
NLP_MODE=openai

# --- OpenAI (only needed if NLP_MODE=openai) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBED_MODEL=text-embedding-ada-002
OPENAI_CHAT_MODEL=gpt-3.5-turbo

# --- Server ---
FLASK_DEBUG=true
FLASK_PORT=5000

# --- Search ---
TOP_K_RESULTS=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
